{
  "name": "Hashbox Studio WordPress Theme",
  "version": "1.0.0",
  "description": "Professional WordPress theme for Hashbox Studio",
  "repository": {
    "type": "git",
    "url": "https://github.com/tumthaweewat/hashbox-landing.git"
  },
  "deployment": {
    "target": "hashbox.co.th",
    "path": "/httpdocs/wp-content/themes/hashbox-studio/",
    "branch": "main",
    "auto_deploy": true,
    "exclude": [
      ".git",
      ".gitignore",
      "deploy/",
      "*.zip",
      "deploy.sh",
      "DEPLOYMENT-GUIDE.md",
      "deploy-config.json"
    ]
  },
  "wordpress": {
    "theme_name": "Hashbox Studio",
    "theme_uri": "https://hashbox.co.th",
    "version": "1.0.0",
    "requires_wp": "6.0",
    "requires_php": "7.4"
  },
  "scripts": {
    "deploy": "./deploy.sh",
    "build": "echo 'No build process required for this theme'"
  }
}